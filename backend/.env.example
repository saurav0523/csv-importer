# ── Server ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Comma separated list of allowed origins for CORS (frontend URL(s))
# Set to * to allow all domains, or specify frontend URL (e.g. http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# ── AI Provider ─────────────────────────────────────────
OPENROUTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── Batching / Processing ───────────────────────────────
# How many CSV rows are sent to the AI model per request
AI_BATCH_SIZE=25
# How many times a failed batch is retried before being marked failed
AI_MAX_RETRIES=3
# Max concurrent batches processed in parallel
AI_CONCURRENCY=1

# ── Upload limits ───────────────────────────────────────
MAX_FILE_SIZE_MB=5
MAX_ROWS_PER_IMPORT=5000

# ── Rate limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
